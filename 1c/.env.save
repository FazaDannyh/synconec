# =====================================================
# ОСНОВНЫЕ НАСТРОЙКИ
# =====================================================
# URL вебхука Bitrix24 (обязательно с завершающим слешем)
BITRIX24_WEBHOOK_URL=https://btx2.ru/rest/203/0000000000000000/
# ID пользователя по умолчанию для назначения сделок
BITRIX24_USER_ID=1
# Режим работы (development/production)
NODE_ENV=development
# Порт сервера
PORT=3000

# =====================================================
# СТАТУСЫ СДЕЛОК BITRIX24
# =====================================================
# Этап "Выставление счета" (новая сделка/документ "Сделка")
DEAL_STAGE_INVOICE=C3:EXECUTING
# Этап "Отгрузка" (документ "Отгрузка")
DEAL_STAGE_SHIPMENT=C3:UC_YCF063
# Этап "Закрыта" (документ "ЗакрытиеСделкиДосрочно")
DEAL_STAGE_CLOSED=C3:FINAL_INVOICE
API_KEY=sqoiufn1iu23!rdfosjndq@roneaksdn$ojgfndjxkaasoifn

# =====================================================
# ПОЛЬЗОВАТЕЛЬСКИЕ ПОЛЯ СДЕЛОК (UF_CRM_*)
# =====================================================
# Поле для хранения GUID заказа из 1С
DEAL_FIELD_GUID=UF_CRM_1754749349622
# Поле для дополнительной информации
DEAL_FIELD_EXTRA_INFO=UF_CRM_EXTRA_INFO
# Множественные строки: товары из счета (каждая позиция отдельной строкой)
DEAL_FIELD_ORDER_PRODUCTS_STRINGS=UF_CRM_1754749224
# Множественные строки: отгруженные товары (накапливается по отгрузкам)
DEAL_FIELD_SHIPPED_PRODUCTS_STRINGS=UF_CRM_1754749401890
# Сумма счета
DEAL_FIELD_INVOICE_SUM=UF_CRM_1754749378156
# Сумма отгруженных товаров (инкрементируется)
DEAL_FIELD_SHIPPED_SUM=UF_CRM_1754749575432
# =====================================================
# НАСТРОЙКИ ОБРАБОТКИ ТОВАРОВ
# =====================================================
# Автоматически создавать товары в каталоге Bitrix24
AUTO_CREATE_PRODUCTS=
# ID каталога товаров по умолчанию
DEFAULT_CATALOG_ID=1
# Валюта по умолчанию
DEFAULT_CURRENCY=RUB

# =====================================================
# НАСТРОЙКИ ЛОГИРОВАНИЯ
# =====================================================
# Уровень логирования (debug/info/warn/error)
LOG_LEVEL=info
# Включить детальное логирование API вызовов
LOG_API_CALLS=false

# =====================================================
# НАСТРОЙКИ ПРОИЗВОДИТЕЛЬНОСТИ
# =====================================================
# Таймаут HTTP запросов к Bitrix24 (мс)
HTTP_TIMEOUT=30000
# Максимальное количество одновременных запросов
MAX_CONCURRENT_REQUESTS=5

DEAL_CATEGORY1_ID=2
DEAL_CATEGORY2_ID=3
# Списки ID департаментов через запятую
DEPARTMENT_CAT1_IDS=21
DEPARTMENT_CAT2_IDS=19


DEAL_STAGE_INVOICE_CAT1=C2:UC_MJE0F9
DEAL_STAGE_SHIPMENT_CAT1=C2:UC_Y6903T
DEAL_STAGE_CLOSED_CAT1=C2:FINAL_INVOICE
# Переопределение стадий для категорий (опционально)
DEAL_STAGE_INVOICE_CAT2=C3:EXECUTING
DEAL_STAGE_SHIPMENT_CAT2=C3:UC_YCF063
DEAL_STAGE_CLOSED_CAT2=C3:FINAL_INVOICE
