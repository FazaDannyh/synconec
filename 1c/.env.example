# Переменные окружения для Битрикс24
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your-webhook-code/
BITRIX24_USER_ID=1

# Настройки сервера
PORT=3000
NODE_ENV=development

# Авторизация API
# Установите AUTH_ENABLED=false для отключения авторизации (НЕ рекомендуется для продакшена)
AUTH_ENABLED=true
# Установите свой уникальный API ключ (обязательно!)
API_KEY=your-very-secure-api-key-here-123456789

# Настройки статусов сделок в Bitrix24 (дефолтная воронка)
DEAL_STAGE_INVOICE=C1:PREPARATION
DEAL_STAGE_SHIPMENT=C1:EXECUTING
DEAL_STAGE_CLOSED=C1:WON

# Воронки (категории) и департаменты
DEAL_CATEGORY1_ID=1
DEAL_CATEGORY2_ID=2
DEAL_CATEGORY3_ID=3
# Списки ID департаментов через запятую
DEPARTMENT_CAT1_IDS=10,11
DEPARTMENT_CAT2_IDS=20,21
DEPARTMENT_CAT3_IDS=30,31

# Переопределение стадий для категорий (опционально)
DEAL_STAGE_INVOICE_CAT1=C1:PREPARATION
DEAL_STAGE_SHIPMENT_CAT1=C1:EXECUTING
DEAL_STAGE_CLOSED_CAT1=C1:WON

DEAL_STAGE_INVOICE_CAT2=C2:PREPARATION
DEAL_STAGE_SHIPMENT_CAT2=C2:EXECUTING
DEAL_STAGE_CLOSED_CAT2=C2:WON

DEAL_STAGE_INVOICE_CAT3=C3:PREPARATION
DEAL_STAGE_SHIPMENT_CAT3=C3:EXECUTING
DEAL_STAGE_CLOSED_CAT3=C3:WON

# Пользовательские поля
DEAL_FIELD_GUID=UF_CRM_GUID_ORDER
DEAL_FIELD_ORIGINAL_PRODUCTS=UF_CRM_ORIGINAL_PRODUCTS
# Строковые множественные поля (существующие в портале)
DEAL_FIELD_ORDER_PRODUCTS_STRINGS=UF_CRM_ORDER_PRODUCTS_STR
DEAL_FIELD_SHIPPED_PRODUCTS_STRINGS=UF_CRM_SHIPPED_PRODUCTS_STR
# Суммарные поля
DEAL_FIELD_INVOICE_SUM=UF_CRM_INVOICE_SUM
DEAL_FIELD_SHIPPED_SUM=UF_CRM_SHIPPED_SUM
# (необязательно) JSON-поля, если будут использоваться
DEAL_FIELD_INVOICE_PRODUCTS_JSON=UF_CRM_INVOICE_PRODUCTS_JSON
DEAL_FIELD_SHIPPED_PRODUCTS_JSON=UF_CRM_SHIPPED_PRODUCTS_JSON

# Пользовательские поля компаний
COMPANY_FIELD_INN=UF_CRM_INN

# Логирование
LOG_LEVEL=info
LOG_API_CALLS=false
